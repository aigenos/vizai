# ── Provider selection ───────────────────────────────────────────────────────
# Analysis provider: "gemini" (default), "claude", or "ollama" (local/free).
PROVIDER=gemini

# ── Provider key (only the selected provider's key is needed) ─────────────────
# Gemini key — https://aistudio.google.com/apikey   (GOOGLE_API_KEY also accepted)
GEMINI_API_KEY=AQ...
# Anthropic key — https://console.anthropic.com/settings/keys (only if PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# Ollama needs no key — just `ollama serve` running locally:
OLLAMA_HOST=http://localhost:11434

# ── Local testing without spending tokens or sending email ───────────────────
# Set PROVIDER=ollama (free local model) and DRY_RUN=true to run the full
# pipeline and write digest_YYYYMMDD.html WITHOUT calling a paid API or Resend.
# In DRY_RUN, RESEND_API_KEY is not required.
DRY_RUN=false

# ── Email delivery (required unless DRY_RUN=true) ────────────────────────────
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re...

# ── Email settings ───────────────────────────────────────────────────────────
EMAIL_TO=youremail@gmail.com
# The default test sender (onboarding@resend.dev) can ONLY send to the email of
# the Resend account owner. To send anywhere else, verify a domain in Resend and
# use e.g. "AI Digest <digest@yourdomain.com>".
EMAIL_FROM=AI Daily Digest <onboarding@resend.dev>

# ── Tuning (optional — sensible defaults baked in) ───────────────────────────
# Model. Leave blank to use the provider default:
#   gemini -> gemini-2.5-flash   |   claude -> claude-sonnet-4-6   |   ollama -> llama3.1
# Examples: gemini-2.5-pro, claude-opus-4-8, qwen2.5, llama3.2
DIGEST_MODEL=

# Two-pass quality/cost split: optional STRONGER model that re-synthesizes just
# the Opportunity sections (the product) while DIGEST_MODEL does the cheap bulk
# summarization. Leave blank for a single pass (exactly the old behavior).
# Example: DIGEST_MODEL=gemini-2.5-flash-lite + OPPORTUNITY_MODEL=gemini-2.5-pro
OPPORTUNITY_MODEL=

# Field preset: retarget the whole briefing to another field with one var.
# ai (default) | security | biotech | fintech — or add your own in src/presets/.
SOURCE_PRESET=ai

# How many days back to consider as "latest". 7 recommended so weekend gaps
# (arXiv doesn't publish Sat/Sun) don't leave the research section empty.
LOOKBACK_DAYS=7

# Web grounding: Gemini -> Google Search, Claude -> web_search tool.
# Set to "false" to run purely from RSS + arXiv (cheaper, less coverage).
ENABLE_WEB_SEARCH=true

# Max arXiv papers to pull per query before ranking.
ARXIV_MAX_RESULTS=40

# Deterministic "Top Stories" strip (thumbnails + ranked links). Off by default:
# it duplicated The Pulse. When enabled it renders below The Pulse.
ENABLE_TOP_STORIES=false

# Write the rendered HTML to disk too (useful for CI artifacts / debugging).
SAVE_HTML=true

# Cross-day dedup: drop items already covered by a previous digest, tracked in
# <ARCHIVE_DIR>/.state/seen_items.json (pruned after LOOKBACK_DAYS * 2 days).
# Fail-open: a missing/corrupt state file just means nothing is filtered.
CROSS_DAY_DEDUP=true

# HEAD-check every link in the digest before sending/publishing; dead links are
# flagged visibly and logged. Fail-open: network trouble never aborts the run.
ENABLE_LINK_CHECK=true

# Show the "powered by <provider> (<model>)" line in the email footer.
SHOW_MODEL_ATTRIBUTION=true

# Unsubscribe link for the email footer — REQUIRED before sending to anyone but
# yourself. Either a URL or your sending platform's merge tag, e.g. Resend:
# UNSUBSCRIBE_URL={{{RESEND_UNSUBSCRIBE_URL}}}
# or Buttondown: UNSUBSCRIBE_URL={{ unsubscribe_url }}
UNSUBSCRIBE_URL=

# ── Public archive (GitHub Pages) ────────────────────────────────────────────
# Publish each day's digest to <ARCHIVE_DIR>/ as a browsable site. PRIVATE
# sections (e.g. the Opportunity Map) are automatically stripped before publish.
PUBLISH_ARCHIVE=false
ARCHIVE_DIR=docs
SITE_TITLE=aigenos — Daily AI Digest
# Public base URL of your Pages site (used to link the full issue in chat posts):
# SITE_URL=https://YOURUSER.github.io/aigenos
# Freemium: the public archive shows 1 "Opportunity of the Day"; the full
# Opportunity Map stays private. Set a subscribe URL to show an upsell CTA on the
# public archive (leave blank to hide it):
# SUBSCRIBE_URL=https://yourdomain.com/subscribe
# One-click subscribe form on the landing page. Set this to your newsletter
# service's POST endpoint and the index renders a real email form (no backend
# needed — works on static GitHub Pages). Buttondown example:
# SUBSCRIBE_FORM_ACTION=https://buttondown.email/api/emails/embed-subscribe/YOURNAME
# Or paste your provider's full form snippet (Buttondown/Beehiiv/...) and it is
# injected verbatim into the subscribe CTA instead — fully provider-agnostic:
# SUBSCRIBE_EMBED_HTML=<form action="..." method="post">...</form>

# ── Audio digest (free, no key — uses gTTS) ──────────────────────────────────
# Voices "The Pulse" to an MP3 in AUDIO_DIR. Needs `pip install gTTS`.
ENABLE_AUDIO=false
AUDIO_DIR=out

# ── Multi-channel delivery (all optional; blank = disabled) ───────────────────
# Posts a short text teaser (The Pulse + link to the full issue) to each channel.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=123456789
