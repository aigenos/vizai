# ── Required ───────────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Email settings ───────────────────────────────────────────────────────────
# Where the daily digest is sent.
EMAIL_TO=mukeshatnyc1@gmail.com

# Sender address. The default test sender (onboarding@resend.dev) can ONLY send
# to the email of the Resend account owner. To send anywhere else, verify a
# domain in Resend and use e.g. "AI Digest <digest@yourdomain.com>".
EMAIL_FROM=AI Daily Digest <onboarding@resend.dev>

# ── Tuning (optional — sensible defaults baked in) ───────────────────────────
# Model used for analysis/synthesis.
DIGEST_MODEL=claude-sonnet-4-6

# How many days back to consider as "latest" (3 covers weekends).
LOOKBACK_DAYS=3

# Let Claude use web search to fill gaps (newsletters, DeepSeek, Anthropic, etc.)
# Set to "false" to run purely from RSS + arXiv (cheaper, less coverage).
ENABLE_WEB_SEARCH=true

# Max arXiv papers to pull per query before ranking.
ARXIV_MAX_RESULTS=40

# Write the rendered HTML to disk too (useful for CI artifacts / debugging).
SAVE_HTML=true
