# ── Provider selection ───────────────────────────────────────────────────────
# Analysis provider: "gemini" (default), "claude", or "ollama" (local/free).
PROVIDER=gemini

# ── Provider key (only the selected provider's key is needed) ─────────────────
# Gemini key — https://aistudio.google.com/apikey   (GOOGLE_API_KEY also accepted)
GEMINI_API_KEY=AIza...
# Anthropic key — https://console.anthropic.com/settings/keys (only if PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-...
# Ollama needs no key — just `ollama serve` running locally:
OLLAMA_HOST=http://localhost:11434

# ── Local testing without spending tokens or sending email ───────────────────
# Set PROVIDER=ollama (free local model) and DRY_RUN=true to run the full
# pipeline and write digest_YYYYMMDD.html WITHOUT calling a paid API or Resend.
# In DRY_RUN, RESEND_API_KEY is not required.
DRY_RUN=false

# ── Email delivery (required unless DRY_RUN=true) ────────────────────────────
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Email settings ───────────────────────────────────────────────────────────
EMAIL_TO=mukeshatnyc1@gmail.com
# The default test sender (onboarding@resend.dev) can ONLY send to the email of
# the Resend account owner. To send anywhere else, verify a domain in Resend and
# use e.g. "AI Digest <digest@yourdomain.com>".
EMAIL_FROM=AI Daily Digest <onboarding@resend.dev>

# ── Tuning (optional — sensible defaults baked in) ───────────────────────────
# Model. Leave blank to use the provider default:
#   gemini -> gemini-2.5-flash   |   claude -> claude-sonnet-4-6   |   ollama -> llama3.1
# Examples: gemini-2.5-pro, claude-opus-4-8, qwen2.5, llama3.2
DIGEST_MODEL=

# How many days back to consider as "latest" (3 covers weekends).
LOOKBACK_DAYS=3

# Web grounding: Gemini -> Google Search, Claude -> web_search tool.
# Set to "false" to run purely from RSS + arXiv (cheaper, less coverage).
ENABLE_WEB_SEARCH=true

# Max arXiv papers to pull per query before ranking.
ARXIV_MAX_RESULTS=40

# Write the rendered HTML to disk too (useful for CI artifacts / debugging).
SAVE_HTML=true
