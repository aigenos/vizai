# Forge configuration — copy to .env and edit. All values are optional;
# sensible defaults are applied. Flags > .env/env > forge.config.json > defaults.

# Which LLM backend to use: ollama | openai | anthropic
FORGE_PROVIDER=ollama

# Model name (defaults per provider if unset):
#   ollama    -> qwen2.5-coder:7b
#   openai    -> gpt-oss
#   anthropic -> claude-opus-4-8
# FORGE_MODEL=qwen2.5-coder:14b

# --- Ollama (fully local) ---
# Start it with `ollama serve` and `ollama pull <model>`.
OLLAMA_HOST=http://localhost:11434

# --- OpenAI-compatible endpoint (vLLM / LM Studio / LocalAI / llama.cpp / OpenRouter / Together ...) ---
# Point at the server's /v1 root.
FORGE_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=sk-...        # only if your endpoint requires auth

# --- Anthropic (optional cloud fallback) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Behavior ---
# Permission mode for file/shell actions:
#   safe     (default) read-only commands auto-run; mutating ones ask for approval
#   auto     run anything non-dangerous without asking (used by the agent team)
#   yolo     run everything, including flagged-dangerous commands
#   readonly never modify the filesystem; only read/search
FORGE_PERMISSION_MODE=safe

# Max tool-using steps per agent turn
FORGE_MAX_STEPS=50

# Generation knobs (temperature is ignored for the Anthropic provider)
FORGE_MAX_TOKENS=8192
FORGE_TEMPERATURE=0.2

# Workspace root the agent is sandboxed to (defaults to the current directory)
# FORGE_WORKSPACE=/path/to/project
