{
  "name": "@aigenos/forge",
  "version": "0.1.0",
  "description": "Forge — a local, self-hosted agentic dev super-app. A Claude Code / Cowork-style terminal agent plus an autonomous agent team (PM, Architect, Coder, Tester, DevOps, Reviewer), pointed at your own LLM services.",
  "type": "module",
  "bin": {
    "forge": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "agents",
    "autonomous",
    "llm",
    "ollama",
    "openai",
    "anthropic",
    "claude-code",
    "cowork",
    "cli",
    "local",
    "self-hosted",
    "coding-agent"
  ],
  "author": "aigenos",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
